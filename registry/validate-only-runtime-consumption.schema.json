{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lode://schema/registry/validate-only-runtime-consumption@0.1.0",
  "title": "Lode validate-only runtime consumption truth",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "truth_id", "truth_version", "asset_owner", "consumer_boundary", "entries", "fail_closed", "non_goals"],
  "properties": {
    "$schema": {"const": "./validate-only-runtime-consumption.schema.json"},
    "schema_version": {"const": "lode.validate-only-runtime-consumption.v0"},
    "truth_id": {"const": "lode.xhs-boss.write-precheck.runtime-consumption"},
    "truth_version": {"const": "0.1.0"},
    "asset_owner": {"const": "Lode"},
    "consumer_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_consumers", "admission_meaning", "runtime_execution", "live_success"],
      "properties": {
        "allowed_consumers": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object"}},
        "admission_meaning": {"type": "string", "minLength": 1},
        "runtime_execution": {"const": "out_of_scope"},
        "live_success": {"const": "not_proven_by_lode"}
      }
    },
    "entries": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/entry"}},
    "fail_closed": {"type": "object", "minProperties": 10, "additionalProperties": {"const": "reject"}},
    "non_goals": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_ref", "lock_ref", "version", "site_slug", "capability_id", "operation_id", "operation_mode", "lifecycle", "allowed_origins", "page_requirement", "resource_requirements", "freshness", "field_sources", "failure_taxonomy", "evidence_and_post_check", "runtime_result_requirements", "safety_boundary"],
      "properties": {
        "package_ref": {"type": "string", "pattern": "^lode://site-capability/"},
        "lock_ref": {"type": "string", "pattern": "^lode://lock/site-capability/"},
        "version": {"const": "0.1.0"},
        "site_slug": {"enum": ["xiaohongshu", "boss"]},
        "capability_id": {"enum": ["publish-note-precheck", "greet-precheck"]},
        "operation_id": {"enum": ["xhs_publish_note_precheck", "boss_greet_precheck"]},
        "operation_mode": {"const": "validate_only"},
        "lifecycle": {"const": "proposed"},
        "allowed_origins": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^https://"}},
        "page_requirement": {"type": "object"},
        "resource_requirements": {"type": "object"},
        "freshness": {"type": "object"},
        "field_sources": {"type": "object"},
        "failure_taxonomy": {"type": "object"},
        "evidence_and_post_check": {"type": "object"},
        "runtime_result_requirements": {"type": "object"},
        "safety_boundary": {"type": "object"}
      }
    }
  }
}
