{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lode://schema/site-capability/example/read-public-page/output@0.1.0",
  "title": "Example Read Public Page Normalized Output",
  "description": "Normalized output contract for the reserved-domain, read-only sample capability package. Core owns the result envelope around this data.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_kind",
    "status",
    "classification",
    "normalized",
    "source_refs",
    "evidence_refs"
  ],
  "properties": {
    "result_kind": {
      "const": "content_detail"
    },
    "status": {
      "type": "string",
      "enum": [
        "available",
        "empty",
        "unavailable"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "success_result",
        "partial_result",
        "empty_result",
        "not_normalizable"
      ]
    },
    "normalized": {
      "oneOf": [
        {
          "$ref": "#/$defs/content_detail"
        },
        {
          "type": "null"
        }
      ]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_ref"
      },
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_ref"
      },
      "default": []
    },
    "empty_reason": {
      "type": "string",
      "enum": [
        "page_has_no_public_content",
        "target_not_found"
      ]
    },
    "unavailable_reason": {
      "type": "string",
      "enum": [
        "source_unavailable",
        "evidence_unavailable",
        "not_normalizable"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "mapping_incomplete",
          "source_refs_partial",
          "evidence_refs_partial"
        ]
      },
      "default": []
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "available"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "classification": {
            "enum": [
              "success_result",
              "partial_result"
            ]
          },
          "normalized": {
            "$ref": "#/$defs/content_detail"
          }
        },
        "required": [
          "source_refs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "empty"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "classification": {
            "const": "empty_result"
          },
          "normalized": {
            "type": "null"
          }
        },
        "required": [
          "empty_reason"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "unavailable"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "classification": {
            "const": "not_normalizable"
          },
          "normalized": {
            "type": "null"
          }
        },
        "required": [
          "unavailable_reason"
        ]
      }
    }
  ],
  "$defs": {
    "content_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_url",
        "title",
        "summary",
        "source_status"
      ],
      "properties": {
        "canonical_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://(www\\.)?example\\.org(?:/.*)?$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_status": {
          "type": "string",
          "enum": [
            "located",
            "partially_located"
          ]
        }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "source_kind",
        "producer",
        "redaction",
        "schema_hint"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "source_kind": {
          "type": "string",
          "enum": [
            "document_summary",
            "http_metadata",
            "dom_snapshot_summary"
          ]
        },
        "producer": {
          "type": "string",
          "enum": [
            "core",
            "harbor",
            "fixture"
          ]
        },
        "redaction": {
          "type": "string",
          "enum": [
            "summary_only",
            "placeholder_only"
          ]
        },
        "schema_hint": {
          "type": "string",
          "examples": [
            "example-read-public-page-source@0.1.0"
          ]
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "evidence_kind",
        "producer",
        "redaction"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "evidence_kind": {
          "type": "string",
          "enum": [
            "snapshot_ref",
            "network_summary_ref",
            "post_check_ref"
          ]
        },
        "producer": {
          "type": "string",
          "enum": [
            "core",
            "harbor",
            "fixture"
          ]
        },
        "redaction": {
          "type": "string",
          "enum": [
            "summary_only",
            "placeholder_only"
          ]
        }
      }
    }
  },
  "examples": [
    {
      "result_kind": "content_detail",
      "status": "available",
      "classification": "success_result",
      "normalized": {
        "canonical_url": "https://example.org/",
        "title": "Example Domain",
        "summary": "Reserved public example page.",
        "source_status": "located"
      },
      "source_refs": [
        {
          "ref_id": "fixture-source-1",
          "source_kind": "document_summary",
          "producer": "fixture",
          "redaction": "summary_only",
          "schema_hint": "example-read-public-page-source@0.1.0"
        }
      ],
      "evidence_refs": []
    },
    {
      "result_kind": "content_detail",
      "status": "empty",
      "classification": "empty_result",
      "normalized": null,
      "source_refs": [],
      "evidence_refs": [],
      "empty_reason": "page_has_no_public_content"
    },
    {
      "result_kind": "content_detail",
      "status": "unavailable",
      "classification": "not_normalizable",
      "normalized": null,
      "source_refs": [],
      "evidence_refs": [],
      "unavailable_reason": "source_unavailable"
    }
  ],
  "x-lode": {
    "schema_id": "example.read-public-page.output",
    "schema_version": "0.1.0",
    "package_ref": "lode://site-capability/example/read-public-page@0.1.0",
    "operation_ref": "lode://operation/content_detail_by_url",
    "result_kind": "content_detail",
    "core_envelope_owner": "WebEnvoy Core",
    "failure_class_mapping": {
      "invalid_contract": "invalid_contract",
      "resource_unavailable": "resource_unavailable",
      "empty": "empty_result",
      "empty_result": "empty_result",
      "site_changed": "site_changed",
      "source_unavailable": "source_unavailable",
      "evidence_unavailable": "evidence_unavailable",
      "not_normalizable": "normalization_failed",
      "mapping_incomplete": "mapping_incomplete"
    },
    "forbidden_inline_fields": [
      "cookies",
      "tokens",
      "profile_state",
      "runtime_session",
      "live_tab_state",
      "raw_evidence_body",
      "production_payload",
      "user_business_data",
      "full_dom",
      "har",
      "screenshot_body"
    ]
  }
}
