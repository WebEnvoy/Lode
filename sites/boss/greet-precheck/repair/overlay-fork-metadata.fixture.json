      "asset_kind": "repair_draft",
      "asset_ref": "lode://repair-draft/site-capability/boss/greet-precheck/site-change@0.1.1-draft",
      "source": "site_changed failure mapping",
      "status": "candidate",
      "boundary": "refs-only fixture with no private browser material"
    },
    {
      "asset_kind": "user_overlay",
      "asset_ref": "lode://overlay/site-capability/boss/greet-precheck/local-field-map@0.1.1-draft",
