  "consumer_boundary": "App may render local report, overlay, fork, and repair draft status as owner-provided facts. Lode owns package/draft truth; Core owns run truth; Harbor owns evidence refs and freshness.",
  "non_goals": [
    "No marketplace.",
    "No hosted sync.",
    "No crawler queue.",
    "No raw runtime material ingestion.",
    "No true write-side execution."
