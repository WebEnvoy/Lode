      "credentials",
      "cookies",
      "tokens",
      "profile state",
      "runtime session",
      "live tab state",
      "full document body",
      "network archive",
      "network response body",
      "production payload",
      "user business data"
    ]
  },
  "private_invalidation_boundary": {
