    "platform_report_status": "lode_public_fix_candidate",
    "forbidden_private_material": [
      "account identity",
      "credential material",
      "browser storage",
      "private page content",
      "raw runtime capture"
    ],
    "app_may_store": "local UI intent and report preference only"
  },
  "overlay_fork_examples": [
