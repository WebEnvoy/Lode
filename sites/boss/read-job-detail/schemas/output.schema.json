{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lode://schema/site-capability/boss/read-job-detail/output@0.1.1",
  "title": "Read BOSS Zhipin job detail Normalized Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_kind",
    "status",
    "classification",
    "normalized",
    "source_refs",
    "evidence_refs"
  ],
  "properties": {
    "result_kind": {
      "const": "boss_job_detail"
    },
    "status": {
      "type": "string",
      "enum": [
        "available",
        "empty",
        "unavailable"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "success_result",
        "partial_result",
        "empty_result",
        "not_normalizable"
      ]
    },
    "normalized": {
      "oneOf": [
        {
          "$ref": "#/$defs/content_detail"
        },
        {
          "type": "null"
        }
      ]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_ref"
      },
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_ref"
      },
      "default": []
    },
    "empty_reason": {
      "type": "string"
    },
    "unavailable_reason": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "$defs": {
    "content_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_url",
        "title",
        "summary",
        "source_status",
        "detail_ref",
        "job",
        "company",
        "recruiter",
        "source_citation"
      ],
      "properties": {
        "canonical_url": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_status": {
          "type": "string",
          "enum": [
            "located",
            "partially_located"
          ]
        },
        "detail_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^detail_ref_[A-Za-z0-9_-]+$",
          "description": "Opaque Core-owned binding to the internal BOSS security identifiers used for this detail read."
        },
        "job": {
          "type": "object"
        },
        "company": {
          "type": "object"
        },
        "recruiter": {
          "type": "object"
        },
        "source_citation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "detail_ref", "url", "field_sources"],
          "properties": {
            "kind": {"const": "boss_job_detail_ref"},
            "detail_ref": {"type": "string", "pattern": "^detail_ref_[A-Za-z0-9_-]+$"},
            "url": {"type": "string", "format": "uri"},
            "field_sources": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
          }
        }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "source_kind",
        "producer",
        "redaction",
        "schema_hint"
      ],
      "properties": {
        "ref_id": {
          "type": "string"
        },
        "source_kind": {
          "type": "string"
        },
        "producer": {
          "type": "string"
        },
        "redaction": {
          "type": "string"
        },
        "schema_hint": {
          "type": "string"
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "evidence_kind",
        "producer",
        "redaction"
      ],
      "properties": {
        "ref_id": {
          "type": "string"
        },
        "evidence_kind": {
          "type": "string"
        },
        "producer": {
          "type": "string"
        },
        "redaction": {
          "type": "string"
        }
      }
    }
  },
  "x-lode": {
    "schema_id": "boss.read-job-detail.output",
    "schema_version": "0.1.1",
    "package_ref": "lode://site-capability/boss/read-job-detail@0.1.1",
    "operation_ref": "lode://operation/boss_read_job_detail",
    "operation_mode": "read",
    "result_owner_boundary": "Core owns the result envelope and internal securityId/encryptJobId binding; Lode owns this normalized public shape, which exposes only detail_ref."
  }
}
