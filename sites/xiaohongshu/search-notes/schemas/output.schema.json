{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lode://schema/site-capability/xiaohongshu/search-notes/output@0.1.0",
  "title": "Search Xiaohongshu notes Normalized Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_kind",
    "status",
    "classification",
    "normalized",
    "source_refs",
    "evidence_refs"
  ],
  "properties": {
    "result_kind": {
      "const": "xhs_note_search"
    },
    "status": {
      "type": "string",
      "enum": [
        "available",
        "empty",
        "unavailable"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "success_result",
        "partial_result",
        "empty_result",
        "not_normalizable"
      ]
    },
    "normalized": {
      "oneOf": [
        {
          "$ref": "#/$defs/content_detail"
        },
        {
          "type": "null"
        }
      ]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_ref"
      },
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_ref"
      },
      "default": []
    },
    "empty_reason": {
      "type": "string"
    },
    "unavailable_reason": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "$defs": {
    "content_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_url",
        "title",
        "summary",
        "source_status",
        "keyword",
        "result_count",
        "notes"
      ],
      "properties": {
        "canonical_url": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_status": {
          "type": "string",
          "enum": [
            "located",
            "partially_located"
          ]
        },
        "keyword": {
          "type": "string"
        },
        "sort": {
          "type": "string"
        },
        "result_count": {
          "type": "integer"
        },
        "has_more": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "source_kind",
        "producer",
        "redaction",
        "schema_hint"
      ],
      "properties": {
        "ref_id": {
          "type": "string"
        },
        "source_kind": {
          "type": "string"
        },
        "producer": {
          "type": "string"
        },
        "redaction": {
          "type": "string"
        },
        "schema_hint": {
          "type": "string"
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "evidence_kind",
        "producer",
        "redaction"
      ],
      "properties": {
        "ref_id": {
          "type": "string"
        },
        "evidence_kind": {
          "type": "string"
        },
        "producer": {
          "type": "string"
        },
        "redaction": {
          "type": "string"
        }
      }
    }
  },
  "x-lode": {
    "schema_id": "xiaohongshu.search-notes.output",
    "schema_version": "0.1.0",
    "package_ref": "lode://site-capability/xiaohongshu/search-notes@0.1.0",
    "operation_ref": "lode://operation/xhs_search_notes",
    "operation_mode": "read",
    "result_owner_boundary": "Core owns the result envelope; Lode owns this normalized public shape."
  }
}
