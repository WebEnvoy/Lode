{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lode://schema/site-capability/xiaohongshu/publish-note-precheck/output@0.1.0",
  "title": "小红书发布草稿写前验证归一化输出",
  "description": "只读确认小红书创作入口，明确 composition 尚未初始化且 submitted=false。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_kind",
    "status",
    "classification",
    "normalized",
    "source_refs",
    "evidence_refs"
  ],
  "properties": {
    "result_kind": {
      "const": "xhs_publish_note_precheck"
    },
    "status": {
      "type": "string",
      "enum": [
        "available",
        "empty",
        "unavailable"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "success_result",
        "partial_result",
        "empty_result",
        "not_normalizable"
      ]
    },
    "normalized": {
      "oneOf": [
        {
          "$ref": "#/$defs/xhs_publish_note_precheck"
        },
        {
          "type": "null"
        }
      ]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_ref"
      },
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_ref"
      },
      "default": []
    },
    "empty_reason": {
      "type": "string",
      "enum": [
        "page_has_no_public_content",
        "target_not_found",
        "target_has_no_writable_surface"
      ]
    },
    "unavailable_reason": {
      "type": "string",
      "enum": [
        "source_unavailable",
        "evidence_unavailable",
        "not_normalizable",
        "resource_unavailable"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "mapping_incomplete",
          "source_refs_partial",
          "evidence_refs_partial"
        ]
      },
      "default": []
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "available"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "classification": {
            "enum": [
              "success_result",
              "partial_result"
            ]
          },
          "normalized": {
            "$ref": "#/$defs/xhs_publish_note_precheck"
          }
        },
        "required": [
          "source_refs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "empty"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "classification": {
            "const": "empty_result"
          },
          "normalized": {
            "type": "null"
          }
        },
        "required": [
          "empty_reason"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "unavailable"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "classification": {
            "const": "not_normalizable"
          },
          "normalized": {
            "type": "null"
          }
        },
        "required": [
          "unavailable_reason"
        ]
      }
    }
  ],
  "$defs": {
    "xhs_publish_note_precheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_url",
        "target_ref",
        "title",
        "summary",
        "source_status",
        "precheck_scope",
        "composition_state",
        "entrypoint_observations",
        "field_states",
        "submitted",
        "prohibited_actions_observed",
        "no_submit_guard_status"
      ],
      "properties": {
        "canonical_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://(www\\.)?xiaohongshu\\.com(?:/.*)?$|^https://creator\\.xiaohongshu\\.com(?:/.*)?$"
        },
        "target_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Harbor/Core 提供的写前目标引用。"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_status": {
          "type": "string",
          "enum": [
            "located",
            "partially_located"
          ]
        },
        "precheck_scope": {
          "const": "entrypoint_only"
        },
        "composition_state": {
          "const": "composition_not_initialized"
        },
        "entrypoint_observations": {
          "$ref": "#/$defs/entrypoint_observations"
        },
        "field_states": {
          "$ref": "#/$defs/field_states"
        },
        "submitted": {
          "const": false
        },
        "prohibited_actions_observed": {
          "type": "object",
          "additionalProperties": false,
          "required": ["upload", "generate", "save", "publish"],
          "properties": {
            "upload": {"const": false},
            "generate": {"const": false},
            "save": {"const": false},
            "publish": {"const": false}
          }
        },
        "no_submit_guard_status": {
          "const": "active"
        }
      }
    },
    "entrypoint_observations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_loaded",
        "user_confirmed_identity",
        "challenge_absent",
        "publish_vue_container_visible",
        "upload_image_tab_active",
        "upload_image_entry_visible",
        "text_image_entry_visible"
      ],
      "properties": {
        "route_loaded": {"const": true},
        "user_confirmed_identity": {"const": true},
        "challenge_absent": {"const": true},
        "publish_vue_container_visible": {"const": true},
        "upload_image_tab_active": {"const": true},
        "upload_image_entry_visible": {"const": true},
        "text_image_entry_visible": {"const": true}
      }
    },
    "field_states": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title_input", "content_editor", "publish_control"],
      "properties": {
        "title_input": {"$ref": "#/$defs/not_observed_field"},
        "content_editor": {"$ref": "#/$defs/not_observed_field"},
        "publish_control": {"$ref": "#/$defs/not_observed_field"}
      }
    },
    "not_observed_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["availability", "observation"],
      "properties": {
        "availability": {"const": "unavailable"},
        "observation": {"const": "not_observed"}
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "source_kind",
        "producer",
        "redaction",
        "schema_hint"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "source_kind": {
          "type": "string",
          "enum": [
            "document_summary",
            "http_metadata",
            "dom_snapshot_summary",
            "creator_publish_page_summary"
          ]
        },
        "producer": {
          "type": "string",
          "enum": [
            "core",
            "harbor",
            "fixture"
          ]
        },
        "redaction": {
          "type": "string",
          "enum": [
            "summary_only",
            "placeholder_only"
          ]
        },
        "schema_hint": {
          "type": "string",
          "examples": [
            "xiaohongshu-publish-note-precheck-source@0.1.0"
          ]
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "evidence_kind",
        "producer",
        "redaction"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "evidence_kind": {
          "type": "string",
          "enum": [
            "snapshot_ref",
            "network_summary_ref",
            "post_check_ref"
          ]
        },
        "producer": {
          "type": "string",
          "enum": [
            "core",
            "harbor",
            "fixture"
          ]
        },
        "redaction": {
          "type": "string",
          "enum": [
            "summary_only",
            "placeholder_only"
          ]
        }
      }
    }
  },
  "examples": [
    {
      "result_kind": "xhs_publish_note_precheck",
      "status": "available",
      "classification": "partial_result",
      "normalized": {
        "canonical_url": "https://creator.xiaohongshu.com/publish/publish?from=menu_left&target=image",
        "target_ref": "writable-target:xiaohongshu/creator-publish-note",
        "title": "小红书发布草稿写前验证",
        "summary": "创作入口已确认；未初始化内容编辑面，未执行任何外部动作。",
        "source_status": "located",
        "precheck_scope": "entrypoint_only",
        "composition_state": "composition_not_initialized",
        "entrypoint_observations": {
          "route_loaded": true,
          "user_confirmed_identity": true,
          "challenge_absent": true,
          "publish_vue_container_visible": true,
          "upload_image_tab_active": true,
          "upload_image_entry_visible": true,
          "text_image_entry_visible": true
        },
        "field_states": {
          "title_input": {"availability": "unavailable", "observation": "not_observed"},
          "content_editor": {"availability": "unavailable", "observation": "not_observed"},
          "publish_control": {"availability": "unavailable", "observation": "not_observed"}
        },
        "submitted": false,
        "prohibited_actions_observed": {"upload": false, "generate": false, "save": false, "publish": false},
        "no_submit_guard_status": "active"
      },
      "source_refs": [
        {
          "ref_id": "fixture-source-1",
          "source_kind": "creator_publish_page_summary",
          "producer": "fixture",
          "redaction": "summary_only",
          "schema_hint": "xiaohongshu-publish-note-precheck-source@0.1.0"
        }
      ],
      "evidence_refs": [
        {
          "ref_id": "fixture-evidence-1",
          "evidence_kind": "snapshot_ref",
          "producer": "fixture",
          "redaction": "placeholder_only"
        }
      ]
    },
    {
      "result_kind": "xhs_publish_note_precheck",
      "status": "empty",
      "classification": "empty_result",
      "empty_reason": "target_has_no_writable_surface"
    },
    {
      "result_kind": "xhs_publish_note_precheck",
      "status": "unavailable",
      "classification": "not_normalizable",
      "unavailable_reason": "resource_unavailable"
    }
  ],
  "x-lode": {
    "schema_id": "xiaohongshu.publish-note-precheck.output",
    "schema_version": "0.1.0",
    "package_ref": "lode://site-capability/xiaohongshu/publish-note-precheck@0.1.0",
    "operation_ref": "lode://operation/xhs_publish_note_precheck",
    "result_kind": "xhs_publish_note_precheck",
    "core_envelope_owner": "WebEnvoy Core",
    "failure_class_mapping": {
      "invalid_contract": "invalid_contract",
      "resource_unavailable": "resource_unavailable",
      "empty": "empty_result",
      "empty_result": "empty_result",
      "site_changed": "site_changed",
      "source_unavailable": "source_unavailable",
      "evidence_unavailable": "evidence_unavailable",
      "preview_unavailable": "preview_unavailable",
      "page_changed": "site_changed",
      "user_cancelled": "user_cancelled",
      "not_normalizable": "normalization_failed",
      "mapping_incomplete": "mapping_incomplete",
      "login_required": "login_required",
      "permission_insufficient": "permission_insufficient",
      "composition_not_initialized": "partial_result",
      "target_not_writable": "target_not_writable",
      "safety_challenge": "safety_challenge"
    },
    "risk_hint_taxonomy": [
      "requires_user_review",
      "target_may_change",
      "evidence_may_stale",
      "no_submit_guard_required"
    ],
    "forbidden_inline_fields": [
      "cookies",
      "tokens",
      "profile_state",
      "runtime_session",
      "live_tab_state",
      "raw_evidence_body",
      "production_payload",
      "user_business_data",
      "full_dom",
      "har",
      "screenshot_body"
    ],
    "covered_issues": [
      "#235",
      "#236",
      "#237",
      "#238",
      "#239"
    ],
    "no_submit_guard": "active",
    "true_write_execution": "blocked"
  }
}
