{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lode://schema/site-capability/xiaohongshu/read-note-detail/output@0.1.0",
  "title": "Read Xiaohongshu note detail Normalized Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_kind",
    "status",
    "classification",
    "normalized",
    "source_refs",
    "evidence_refs"
  ],
  "properties": {
    "result_kind": {
      "const": "xhs_note_detail"
    },
    "status": {
      "type": "string",
      "enum": [
        "available",
        "empty",
        "unavailable"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "success_result",
        "partial_result",
        "empty_result",
        "not_normalizable"
      ]
    },
    "normalized": {
      "oneOf": [
        {
          "$ref": "#/$defs/content_detail"
        },
        {
          "type": "null"
        }
      ]
    },
    "source_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/source_ref"
      },
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/evidence_ref"
      },
      "default": []
    },
    "empty_reason": {
      "type": "string"
    },
    "unavailable_reason": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "allOf": [{
    "if": {"properties": {"status": {"const": "available"}}, "required": ["status"]},
    "then": {
      "properties": {
        "normalized": {"$ref": "#/$defs/content_detail"},
        "source_refs": {"minItems": 1},
        "evidence_refs": {"minItems": 1}
      }
    }
  }],
  "$defs": {
    "content_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_url",
        "title",
        "summary",
        "source_status",
        "note_id",
        "author",
        "body_summary",
        "interaction_metrics",
        "source_citation"
      ],
      "properties": {
        "canonical_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://www\\.xiaohongshu\\.com/explore/[A-Za-z0-9]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000,
          "pattern": "^.*\\S.*$"
        },
        "source_status": {
          "type": "string",
          "enum": [
            "located",
            "partially_located"
          ]
        },
        "note_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9]+$"
        },
        "author": {
          "type": "object",
          "additionalProperties": false,
          "required": ["display_name", "author_id", "profile_url"],
          "properties": {
            "display_name": {"type": "string", "minLength": 1, "pattern": "^.*\\S.*$"},
            "author_id": {"type": "string", "minLength": 1},
            "profile_url": {"type": "string", "format": "uri", "pattern": "^https://www\\.xiaohongshu\\.com/user/profile/[A-Za-z0-9_]+$"}
          }
        },
        "body_summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000,
          "pattern": "^.*\\S.*$"
        },
        "interaction_metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["likes", "comments", "collects", "shares"],
          "properties": {
            "likes": {"type": "string"},
            "comments": {"type": "string"},
            "collects": {"type": "string"},
            "shares": {"type": "string"}
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "published_at": {
          "type": "string"
        },
        "ip_location": {
          "type": "string"
        },
        "source_citation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "note_id", "url", "field_sources"],
          "properties": {
            "kind": {"const": "xhs_note_detail_ref"},
            "note_id": {"type": "string", "pattern": "^[A-Za-z0-9]+$"},
            "url": {"type": "string", "format": "uri", "pattern": "^https://www\\.xiaohongshu\\.com/explore/[A-Za-z0-9]+$"},
            "field_sources": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
          }
        }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "source_kind",
        "producer",
        "redaction",
        "schema_hint"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._:-]{2,127}$"
        },
        "source_kind": {
          "type": "string"
        },
        "producer": {
          "type": "string"
        },
        "redaction": {
          "type": "string"
        },
        "schema_hint": {
          "type": "string"
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "evidence_kind",
        "producer",
        "redaction"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._:-]{2,127}$"
        },
        "evidence_kind": {
          "type": "string"
        },
        "producer": {
          "type": "string"
        },
        "redaction": {
          "type": "string"
        }
      }
    }
  },
  "x-lode": {
    "schema_id": "xiaohongshu.read-note-detail.output",
    "schema_version": "0.1.0",
    "package_ref": "lode://site-capability/xiaohongshu/read-note-detail@0.1.0",
    "operation_ref": "lode://operation/xhs_read_note_detail",
    "operation_mode": "read",
    "result_owner_boundary": "Core owns the result envelope; Lode owns this normalized public shape."
  }
}
